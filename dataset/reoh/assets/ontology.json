  "intents": {
    "greeting": {
      "description": "An initial greeting to establish rapport (e.g., 'Hello! Welcome to the open house.', 'Hello! I'm looking forward to it.')."
    },
    "acknowledgement": {
      "description": "A short response indicating that the speaker has heard and understood the previous statement (e.g., 'Got it!', 'I see')."
    },
    "gratitude-expression": {
      "description": "Expressing gratitude and its response at the end or during the interaction (e.g., 'Thank you for taking the time to tour this home!', 'Thank you for touring me today.')."
    },
    "positive-expression": {
      "description": "A positive statement or feedback (e.g., 'This room looks great!', 'I love the view', 'That sounds nice.')."
    },
    "negative-expression": {
      "description": "A negative statement or feedback (e.g., 'I'm not sure about this layout', 'This room feels small', 'That's a pity.)."
    },
    "neutral-expression": {
      "description": "A neutral statement or feedback that does not express a strong opinion (e.g., 'Interesting', 'That's good to know')."
    },
    "inform": {
      "description": "Providing information about the property, features, layout, or personal information (e.g., 'This room has a walk-in closet and a private bathroom', 'I like cooking so this feature is great.')."
    },
    "request": {
      "description": "Asking for information or feedback (e.g., 'What do you think of this room?', 'Do you have any specific preferences?', 'What do you enjoy during a break?')."
    },
    "guidance": {
      "description": "Providing directions or instructions for the user to follow (e.g., 'Please follow me to the next room', 'Let's head to the living room')."
    },
    "closing": {
      "description": "A statement signaling the end of the conversation or tour (e.g., 'That concludes our tour. Let me know if you have any questions!', 'I think I could get all the information I want to know.')."
    },
    "done": {
